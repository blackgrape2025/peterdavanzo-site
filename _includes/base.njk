<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ title }} | Peter Da Vanzo</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/style.css"/>
</head>

<body class="{{ bodyClass | default('site-page') }}">

<main class="site-shell">

  <header class="site-header">
    <a class="site-title" href="/">Peter Da Vanzo</a>

    <nav class="site-nav">
      <a href="/writing/" class="{% if activeSection == 'writing' %}is-active{% endif %}">Writing</a>
      <a href="/library/" class="{% if activeSection == 'library' %}is-active{% endif %}">Library</a>
      <a href="/now/" class="{% if activeSection == 'now' %}is-active{% endif %}">Now</a>
      <a href="/about/" class="{% if activeSection == 'about' %}is-active{% endif %}">About</a>
    </nav>
  </header>

  {{ content | safe }}

</main>

</body>
</html>
