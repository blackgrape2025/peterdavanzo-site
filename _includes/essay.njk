---
layout: base.njk
bodyClass: essay-page
activeSection: writing
---

<article class="article-page">

  <header class="article-header">
    {% if date %}
      <div class="article-meta">{{ date | readableDate }}</div>
    {% endif %}

    <h1>{{ title }}</h1>
  </header>

  

  <section class="article-body">
    {{ content | safe }}
  </section>

<p class="article-signoff">
  &copy; <a href="https://peterdavanzo.com" rel="author">Peter Da Vanzo</a>
</p>


</article>
